# ── Florissant Immobilier — environment variables ──
# Copy this file to ".env" and fill in the values. Never commit ".env".

# PostgreSQL connection string (local dev example shown).
# In production, use your managed database URL (Neon, Supabase, Railway…).
DATABASE_URL="postgresql://user@localhost:5432/florissant_development"

# Admin login (the only account that can manage the site).
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="change-me-to-a-strong-password"

# Secret used to sign the admin session cookie. Generate with:
#   openssl rand -hex 32
AUTH_SECRET="generate-a-long-random-string"

# Public URL of the live site (used for SEO, sitemap, social sharing).
NEXT_PUBLIC_SITE_URL="https://florissant-immobilier.ch"
