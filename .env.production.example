# ── Florissant Immobilier — VPS production settings ──
# On the server: copy this file to ".env" (same folder as docker-compose.yml)
# and fill every value. docker compose reads it automatically.

# Your domain (DNS A-record must point to the VPS IP). Caddy gets HTTPS for it.
DOMAIN=florissant-immobilier.ch

# Public URL of the site (https + your domain).
NEXT_PUBLIC_SITE_URL=https://florissant-immobilier.ch

# Database password (choose a long random one — used only inside the server).
DB_PASSWORD=change-me-to-a-long-random-password

# Admin account (the only login that can manage the site).
ADMIN_EMAIL=glen.egbide@gmail.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret that signs the admin session cookie. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=paste-a-64-character-random-hex-string
